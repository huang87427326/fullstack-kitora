{
  // ────────────────────────────────────────────────────────────────
  // Tailwind CSS v4
  //
  // VSCode 内置 CSS 语言服务器不认识 Tailwind v4 的 @theme / @apply /
  // @layer / @variant / @utility 等指令，会把它们标红为 unknownAtRules。
  // 这里把 *.css 关联到 Tailwind CSS 语言服务，并关闭内置校验的未知
  // at-rule 告警作为双保险。
  // ────────────────────────────────────────────────────────────────
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",

  // 让 Tailwind IntelliSense 在 cva(...) / cn(...) 调用里也能补全类名
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
  ],

  // ────────────────────────────────────────────────────────────────
  // ESLint + Prettier
  // ────────────────────────────────────────────────────────────────
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],

  // TypeScript SDK / import specifier 相关设置已从这里移除：
  //   - typescript.tsdk / typescript.enablePromptUseWorkspaceTsdk /
  //     typescript.preferences.importModuleSpecifier 在新版 VSCode 中已弃用
  //   - 采用默认行为即可：VSCode 会自动探测 workspace TypeScript 版本，
  //     import 路径默认使用 "shortest"，符合本仓库习惯
  //
  // ────────────────────────────────────────────────────────────────
  // 其他杂项
  // ────────────────────────────────────────────────────────────────
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "pnpm-lock.yaml": true
  }
}
