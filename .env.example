# ============================================================
# Kitora 环境变量样例
#
# 使用方式：
#   cp .env.example .env.local      # 本地开发
#   Vercel：在 Project Settings → Environment Variables 里配置
#
# 规范：
# - 服务端变量：SCREAMING_SNAKE_CASE，无前缀
# - 客户端变量：必须以 NEXT_PUBLIC_ 前缀才会被注入浏览器 bundle
# - 所有变量默认留空。真正的值只存在于 .env.local 与 Vercel，**禁止**提交到 git
# ============================================================


# ---------- Runtime ----------

# 当前运行环境：development | production | test
# 一般由框架自动设置，这里只在需要脚本显式分支时读取
NODE_ENV=development


# ---------- App URLs ----------
# 三个 app 对外的公共 URL。本地开发时指向 localhost；生产环境指向真实域名
# 详细规划见 docs/ARCHITECTURE.md §12.4

NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_MARKETING_URL=http://localhost:3002


# ---------- Database (Supabase Postgres) ----------
# DATABASE_URL：应用运行时查询走的 pooled 连接（Supavisor / port 6543）
# DIRECT_URL：Prisma migrate / introspect 必须走的直连（port 5432），只在迁移时使用
# 详细说明见 docs/ARCHITECTURE.md §6.1

DATABASE_URL=postgresql://postgres:PASSWORD@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres


# ---------- Supabase Auth ----------
# 公共可暴露的项目 URL + 匿名 key，浏览器侧使用

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 服务端专用 service_role key：拥有所有权限，**严禁**加 NEXT_PUBLIC_ 前缀
SUPABASE_SERVICE_ROLE_KEY=


# ---------- Email (Resend) ----------
# 详细说明见 docs/ARCHITECTURE.md §9

RESEND_API_KEY=
# 发件人身份，建议"Kitora <hello@mail.kitora.co>"形式
EMAIL_FROM=Kitora <hello@mail.kitora.co>
# 系统邮件的统一回信地址
EMAIL_REPLY_TO=support@kitora.co


# ---------- Payments (Lemon Squeezy) ----------
# 详细说明见 docs/ARCHITECTURE.md §8

LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=


# ---------- Observability ----------
# 三件套说明见 docs/ARCHITECTURE.md §11

# Sentry：前端 + 后端错误捕获
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog：产品分析 + feature flags
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Better Stack Uptime（可选，MVP 可延后）
BETTER_STACK_UPTIME_TOKEN=
